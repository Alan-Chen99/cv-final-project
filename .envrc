# Per-worktree venv on scratch (avoids filling NFS home)
_nfs_source=$(findmnt -n -o SOURCE /workspace 2>/dev/null)
export UV_PROJECT_ENVIRONMENT="$HOME/orcd/scratch/venvs/${_nfs_source##*/}"
export UV_CACHE_DIR="$HOME/orcd/scratch/uv-cache"

# Symlink .venv so gpu scripts' `source .venv/bin/activate` keeps working
[ -L .venv ] || { rm -rf .venv && ln -s "$UV_PROJECT_ENVIRONMENT" .venv; }

source "$UV_PROJECT_ENVIRONMENT/bin/activate" 2>/dev/null || true
